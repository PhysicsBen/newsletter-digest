GEMINI_API_KEY=your-gemini-api-key

# LLM config
# Gemini (cloud): LLM_MODEL=gemini/gemini-3.1-flash-lite
# Local Qwen3:    LLM_MODEL=ollama/qwen3:14b
LLM_MODEL=gemini/gemini-3.1-flash-lite
LLM_THINKING_LEVEL=low   # Gemini only
# LLM_TEMPERATURE=        # leave unset to use provider defaults (1.0 for Gemini 3)
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_CONCURRENCY=3       # parallel LLM workers; keep low to avoid Gemini rate limits
# LLM_RETRIES=5
PROMPT_VERSION=v1.0

# Gmail config
GMAIL_LABEL=AI Newsletters
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
# Headless / Railway: paste the raw JSON content of token.json here.
# Generate locally with: python -c "from src.gmail_client import _get_credentials; _get_credentials()"
# then copy the contents of token.json into this variable.
GMAIL_TOKEN_JSON=

# Where to email the finished digest
DIGEST_RECIPIENT_EMAIL=your@email.com

# Database
# Local dev default (SQLite):
DATABASE_URL=sqlite:///data/newsletter.db
# Railway: the Postgres plugin sets this automatically (postgres://user:pass@host/db)

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Pipeline
STALENESS_DAYS=30
DEDUP_SIMILARITY_THRESHOLD=0.87
TOPIC_SIMILARITY_THRESHOLD=0.82
DIGEST_SIGNIFICANCE_MIN_SCORE=5.0
TOKEN_BUDGET=6000
