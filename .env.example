GEMINI_API_KEY=your-gemini-api-key

# LLM config
# Gemini (cloud): LLM_MODEL=gemini/gemini-3.1-flash-lite
# Local Qwen3:    LLM_MODEL=ollama/qwen3:14b
LLM_MODEL=gemini/gemini-3.1-flash-lite
LLM_THINKING_LEVEL=low   # Gemini only
# LLM_TEMPERATURE=        # leave unset to use provider defaults
# OLLAMA_BASE_URL=http://localhost:11434
PROMPT_VERSION=v1.0

# Gmail config
GMAIL_LABEL=Newsletters/AI
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Database
DATABASE_URL=sqlite:///data/newsletter.db

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3

# Pipeline
STALENESS_DAYS=30
TOPIC_SIMILARITY_THRESHOLD=0.82
TOKEN_BUDGET=6000
